rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    /// Returns true when the request is made by a signed-in user
    function isAuthed() {
      return request.auth != null;
    }

    /// Returns true when the authenticated user owns the given uid doc
    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // ── /users/{uid} ──────────────────────────────────────────────────────────
    // Any authenticated user can read any profile.
    // Only the owner can write their own profile document.

    match /users/{uid} {
      allow read:  if isAuthed();
      allow write: if isOwner(uid);

      // ── /users/{uid}/followers/{followerUid} ─────────────────────────────
      // Readable by any authed user.
      // Write is restricted to Cloud Functions (via Admin SDK) to keep
      // follower/following subcollections in sync atomically.
      // Client-side writes are rejected — use the followUser callable instead.

      match /followers/{followerUid} {
        allow read:  if isAuthed();
        allow write: if false; 
      }

      // ── /users/{uid}/following/{followedUid} ─────────────────────────────
      // Readable by any authed user.
      // The owner can write directly (optimistic client updates are still
      // protected because the CF does the canonical batch write).

      match /following/{followedUid} {
        allow read:  if isAuthed();
        allow write: if false;
      }
    }

    // ── /feedPosts/{postId} ───────────────────────────────────────────────────
    // Any authed user can read and create posts.
    // Only the post author can delete their own post.
    // Nobody can update a post once published.

    match /feedPosts/{postId} {
      allow read:   if isAuthed();
      allow create: if isAuthed() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthed() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }
  }
}
