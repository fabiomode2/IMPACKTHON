{
  "rules": {
    "users": {
      ".read": "auth != null",
      ".indexOn": ["username_lowercase", "streakDays"],
      "$uid": {
        // Main profile write remains owner-only
        ".write": "auth != null && auth.uid === $uid",
        
        "followers": {
          "$followerUid": {
            // A user can be added to followers by themselves (following action) 
            // or removed by themselves (unfollow/delete account action)
            ".write": "auth != null && (auth.uid === $uid || auth.uid === $followerUid)"
          }
        },
        "following": {
          "$followedUid": {
            // A user can update their own following list, 
            // or a deleted user can remove themselves from others' following lists
            ".write": "auth != null && (auth.uid === $uid || auth.uid === $followedUid)"
          }
        }
      }
    },
    "usernames": {
      ".read": true,
      "$username": {
        ".write": "auth != null && (!data.exists() || data.val() === auth.uid)"
      }
    },
    "feedPosts": {
      ".read": "auth != null",
      // Allow creating posts, and modifying/deleting only your own posts
      ".write": "auth != null && (!data.exists() || data.child('uid').val() === auth.uid || newData.child('uid').val() === auth.uid)"
    },
    "status": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
