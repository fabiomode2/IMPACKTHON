{
  "rules": {
    "users": {
      "$uid": {
        // Any authenticated user can read profiles (social features)
        ".read": "auth != null",
        // Only the owner can write their profile and sub-nodes (settings, etc.)
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "usernames": {
      // PROBABLE FIX: Registration needs to check if a name is taken BEFORE login occurs.
      // Changing .read to true allows unauthenticated users to check username availability.
      ".read": true,
      "$username": {
        // Allows creating a new username entry or updating your own
        // (prevents overwriting someone else's username entry)
        ".write": "auth != null && (!data.exists() || data.val() === auth.uid)"
      }
    },
    "feedPosts": {
      // Global feed is public for all logged in users
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
